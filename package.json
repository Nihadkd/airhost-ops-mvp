{
    "name": "airhost-ops-mvp",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "postinstall": "prisma generate",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "control:check": "node ./scripts/control-agent.mjs",
        "control:fix": "node ./scripts/control-agent.mjs --fix",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "smoke": "node ./scripts/smoke-test.mjs",
        "verify:ui": "node ./scripts/verify-local-ui.cjs",
        "verify:all": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-all.ps1",
        "db:generate": "prisma generate",
        "db:local:start": "npx prisma dev --detach --name servnest --port 51217 --db-port 51218 --shadow-db-port 51219",
        "db:local:stop": "npx prisma dev stop servnest",
        "db:local:reset": "node ./scripts/db-local-reset.cjs",
        "db:deploy": "prisma migrate deploy",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:seed": "prisma db seed",
        "setup": "npm install && npm run db:local:start && npm run db:local:reset && npm run db:seed",
        "verify": "npm run control:check && npm run test && npm run lint && npm run typecheck && npm run build",
        "quality:check": "node ./scripts/quality-agent.mjs",
        "quality:code": "node ./scripts/quality-agent.mjs --no-visual",
        "quality:visual": "node ./scripts/quality-agent.mjs --visual-only",
        "quality:autofix": "node ./scripts/quality-agent.mjs --auto-fix",
        "demo:filters:live": "node ./scripts/create-filter-demo-orders-live.cjs",
        "verify:public-filters:live": "node ./scripts/verify-public-home-filters-live.cjs",
        "deploy:preview": "npm run quality:check && npx vercel --yes",
        "deploy:prod": "npm run quality:check && npx vercel --prod --yes",
        "release:android:preview": "npm run quality:check && npx vercel --prod --yes && npm --prefix mobile run build:android:preview",
        "release:all:preview": "npm run quality:check && npx vercel --prod --yes && npm --prefix mobile run build:all:preview",
        "autopilot": "powershell -ExecutionPolicy Bypass -File ./scripts/autopilot.ps1",
        "share": "lt --port 3000"
    },
    "prisma": {
        "seed": "node prisma/seed.cjs"
    },
    "dependencies": {
        "@prisma/client": "^6.19.2",
        "bcryptjs": "^3.0.2",
        "lucide-react": "^1.0.1",
        "motion": "^12.38.0",
        "next": "16.1.6",
        "next-auth": "^5.0.0-beta.30",
        "prisma": "^6.19.2",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-hot-toast": "^2.6.0",
        "zod": "^4.1.11",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^9",
        "eslint-config-next": "16.1.6",
        "localtunnel": "^2.0.2",
        "playwright": "^1.58.2",
        "svgo": "^4.0.1",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vitest": "^4.0.18"
    }
}
