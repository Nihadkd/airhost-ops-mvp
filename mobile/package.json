{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:android:preview": "eas build -p android --profile preview",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:all:preview": "eas build --platform all --profile preview",
    "build:all:preview:ci": "eas build --platform all --profile preview --non-interactive",
    "build:android:production": "eas build -p android --profile production",
    "build:all:production": "eas build --platform all --profile production",
    "build:all:production:ci": "eas build --platform all --profile production --non-interactive",
    "submit:android:production": "eas submit -p android --profile production"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eas-cli": "^18.0.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
